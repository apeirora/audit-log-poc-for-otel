{
  "kind": "GlobalDatasource",
  "metadata": {
    "name": "prometheus"
  },
  "spec": {
    "default": true,
    "plugin": {
      "kind": "PrometheusDatasource",
      "spec": {
        "proxy": {
          "kind": "HTTPProxy",
          "spec": {
            "url": "http://prometheus-server.tier-3.svc.cluster.local"
          }
        }
      }
    }
  }
}
